PYTHONPATH=.

# JWT 签名密钥
SECRET_KEY=AetherWeave-SuperSecretKey-2026

# 数据库连接 URI
# SQLite (本地开发):
DATABASE_URL=sqlite:///aetherweave.db
# PostgreSQL (生产):
# DATABASE_URL=postgresql://user:pass@localhost:5432/aetherweave

# JWT Token 过期天数
JWT_EXPIRATION_DAYS=1

# Flask 后端端口
PORT=5001

# 生产环境设置为 production，会启用 console.log 移除等优化
NODE_ENV=development

# Version/build mapping shown by /api/health
APP_VERSION=1.0.0
VCS_REF=local
VCS_BRANCH=master
BUILD_DATE=local
WEB_CONCURRENCY=2
GUNICORN_THREADS=4
