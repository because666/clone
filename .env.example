# ============================================
# AetherWeave 环境变量配置模板
# 复制为 .env 并根据环境修改值
# ============================================

# Python 路径（确保可以找到 trajectory_lab 模块）
PYTHONPATH=.

# ---- Flask 应用配置 ----
# JWT 签名密钥（生产环境必须修改！）
SECRET_KEY=AetherWeave-SuperSecretKey-2026

# 数据库连接 URI
# SQLite (本地开发):
DATABASE_URL=sqlite:///aetherweave.db
# PostgreSQL (生产):
# DATABASE_URL=postgresql://user:pass@localhost:5432/aetherweave

# JWT Token 过期天数
JWT_EXPIRATION_DAYS=1

# ---- 服务端口 ----
# Flask 后端端口
PORT=5001

# ---- 部署环境 ----
# 生产环境设置为 production，会启用 console.log 移除等优化
NODE_ENV=development
